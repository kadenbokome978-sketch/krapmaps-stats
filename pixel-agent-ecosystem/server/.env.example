# Port the relay listens on. The dashboard frontend connects to
# ws://<host>:<PORT>/live by default.
PORT=8787

# Shared secret required in the `x-relay-secret` header on inbound
# POST /events and POST /operator-action calls. Set this to something
# random and put the same value wherever you're posting events from.
RELAY_INGEST_SECRET=change-me

# Optional. If set, operator actions (approve/reject/retry/terminate)
# performed in the dashboard get forwarded here as a best-effort POST
# so your OpenClaw-side integration can act on them. This is NOT a
# confirmed OpenClaw endpoint - point it at whatever your own adapter
# (skill/plugin/webhook receiver) exposes.
OPENCLAW_CALLBACK_URL=

# Optional. Connects this relay directly to OpenClaw's own Gateway
# WebSocket instead of (or alongside) POST /events - see
# openclawGatewayAdapter.js for what's verified vs best-effort about this.
# Run this relay on the same machine as the gateway (it's loopback-only
# by default). The port below is what OpenClaw's own onboarding printed;
# find the token in ~/.openclaw/openclaw.json or via `openclaw gateway status`.
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Which dashboard room newly-discovered agents default into until you
# give them a real one. Must be one of: bridge, workshop, treasury,
# radar, research.
OPENCLAW_DEFAULT_ROOM=bridge
